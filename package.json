{
  "name": "cha_portfolio",
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf _site",
    "build:css": "sass src/scss:src/assets/css --no-source-map",
    "watch:css": "sass src/scss:src/assets/css --watch --no-source-map",
    "build:site": "eleventy",
    "serve:site": "eleventy --serve",
    "cms:proxy": "decap-server",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "npm run clean && npm run build:css && npm run build:site",
    "dev": "run-s build:css && run-p watch:css serve:site cms:proxy"
  },
  "license": "ISC",
  "description": "Portfolio site for a comic book writer and illustrator, built with Eleventy + SCSS + Handlebars.",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-handlebars": "^1.0.0",
    "decap-server": "^3.5.2",
    "handlebars": "^4.7.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "sass": "^1.97.3"
  },
  "dependencies": {
    "lucide-static": "^0.577.0"
  }
}
