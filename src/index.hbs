---
layout: layouts/base.hbs
title: Home
---

<section class="hero-section">
  <div class="layout-container">
    <div class="hero">
      <div class="hero-content">
        <p class="hero-badge">{{ home.hero_tagline }}</p>
        <h1>{{ home.hero_name }}</h1>
        <p class="intro">{{ home.intro }}</p>
        <div class="hero-actions">
          <a class="cta-link" href="/portfolio/">{{ home.cta_text }}</a>
          <a class="cta-link cta-link-outline" href="/contact/"
            >{{t "common.contact" settings.lang i18n}}</a
          >
        </div>
      </div>
      <div class="hero-media">
        <div class="hero-image-glow"></div>
        <div class="hero-image-frame">
          {{#if home.hero_image}}
          <img src="{{ home.hero_image }}" alt="{{ home.hero_name }}" />
          {{else}} {{> icons/user class="hero-fallback-icon"}} {{/if}}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="gallery-section">
  <div class="layout-container">
    <div class="gallery">
      <div class="gallery-head">
        <div>
          <h2>{{home.gallery_title}}</h2>
          <p>{{home.gallery_intro}}</p>
        </div>
        <a class="gallery-view-all" href="/gallery/">
          <span>{{site.view_all_link}}</span>
          {{> icons/arrow-right class="icon-nav"}}
        </a>
      </div>
      <div class="books-grid">
        {{#each (take collections.published_books 4)}} {{> components/book-card/book-card
        book=this.data book_url=this.url}} {{/each}}
      </div>
    </div>
  </div>
</section>

<section class="bottom-section">
  <div class="layout-container">
    <div class="home-feed-grid">
      <div class="feed-column">
        <div class="feed-heading">
          {{> icons/calendar class="icon-lg"}}
          <h2>{{home.event_title}}</h2>
        </div>
        <div class="feed-cards">
          {{#each (take collections.events 3)}} {{> components/small-event-card/small-event-card
          event=this.data event_url=this.url}} {{/each}}
        </div>
        {{#if (gt (count collections.events) 3)}}
        <a class="feed-more-link" href="/events/"
          >{{t "home.view_all_quests" settings.lang i18n}}</a
        >
        {{/if}}
      </div>

      <div class="feed-column">
        <div class="feed-heading">
          {{> icons/book-open class="icon-lg"}}
          <h2>{{home.blog_post_title}}</h2>
        </div>
        <div class="feed-cards">
          {{#each (take collections.blog_posts 3)}} {{> components/small-blog-card/small-blog-card
          post=this.data post_url=this.url}} {{/each}}
        </div>
        {{#if (gt (count collections.blog_posts) 3)}}
        <a class="feed-more-link" href="/blog/">{{t "common.read_more" settings.lang i18n}}</a>
        {{/if}}
      </div>
    </div>
  </div>
</section>

{{!
<p class="cms-link"><a href="/admin/">Open CMS</a></p>
}}
