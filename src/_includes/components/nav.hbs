<header class="site-header">
  <nav class="site-nav layout-container">
    <a class="logo" href="/">
      {{> icons/feather class="icon-md logo-mark"}}
      <span class="logo-text">{{ settings.logo_text }}</span>
    </a>

    <div class="desktop-nav">
      {{#each collections.pages}}
        <a href="{{ this.url }}">
          <span>{{ this.data.title }}</span>
        </a>
      {{/each}}
      <button class="lang-toggle" type="button" aria-label="Toggle language">
        {{> icons/globe class="icon-nav"}}
        <span>{{ settings.language_label }}</span>
      </button>
    </div>

    <details class="mobile-nav">
      <summary aria-label="Open menu">
        {{> icons/scroll class="icon-lg"}}
      </summary>
      <div class="mobile-nav-panel">
        {{#each collections.pages}}
          <a href="{{ this.url }}">
            <span>{{ this.data.title }}</span>
          </a>
        {{/each}}
        <button class="lang-toggle" type="button" aria-label="Toggle language">
          {{> icons/globe class="icon-nav"}}
          <span>{{ settings.language_label }}</span>
        </button>
      </div>
    </details>
  </nav>
</header>
