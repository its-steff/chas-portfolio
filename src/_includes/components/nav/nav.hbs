<header class="site-header">
  <nav class="site-nav layout-container">
    <a class="logo" href="/">
      {{> icons/feather class="icon-md logo-mark"}}
      <span class="logo-text">{{ settings.logo_text }}</span>
    </a>

    <div class="desktop-nav">
      {{#each collections.pages}}
      <a href="{{ this.url }}">
        <span>{{ this.data.title }}</span>
      </a>
      {{/each}}
      <button
        data-lang-toggle
        class="lang-toggle"
        type="button"
        aria-label="{{t 'common.toggle_language' lang i18n}}"
      >
        {{> icons/globe class="icon-nav"}}
        <span>{{#if (eq lang "no")}}NO{{else}}EN{{/if}}</span>
      </button>
    </div>

    <details class="mobile-nav">
      <summary aria-label="{{t 'common.open_menu' lang i18n}}">
        {{> icons/scroll class="icon-lg"}}
      </summary>
      <div class="mobile-nav-panel">
        {{#each collections.pages}}
        <a href="{{ this.url }}">
          <span>{{ this.data.title }}</span>
        </a>
        {{/each}}
        <button
          data-lang-toggle
          class="lang-toggle"
          type="button"
          aria-label="{{t 'common.toggle_language' lang i18n}}"
        >
          {{> icons/globe class="icon-nav"}}
          <span>{{#if (eq lang "no")}}NO{{else}}EN{{/if}}</span>
        </button>
      </div>
    </details>
  </nav>
</header>
