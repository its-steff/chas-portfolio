<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }} | Comic Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav container">
          <a class="logo" href="/">
            {{> icons/feather class="icon-md logo-mark"}}
            <span class="logo-text">Cha's Illustration</span>
          </a>

          <div class="desktop-nav">
            <a href="/portfolio/">
              {{> icons/scroll class="icon-nav"}}
              <span>Gallery</span>
            </a>
            <a href="/blog/">
              {{> icons/book-open class="icon-nav"}}
              <span>Chronicles</span>
            </a>
            <a href="/about/">
              {{> icons/user class="icon-nav"}}
              <span>Wanderer</span>
            </a>
            <a href="/events/">
              {{> icons/calendar class="icon-nav"}}
              <span>Quests</span>
            </a>
            <a href="/contact/">
              {{> icons/mail class="icon-nav"}}
              <span>Contact</span>
            </a>
            <button class="lang-toggle" type="button" aria-label="Toggle language">
              {{> icons/globe class="icon-nav"}}
              <span>EN</span>
            </button>
          </div>

          <details class="mobile-nav">
            <summary aria-label="Open menu">
              {{> icons/scroll class="icon-lg"}}
            </summary>
            <div class="mobile-nav-panel">
              <a href="/portfolio/">
                {{> icons/scroll class="icon-nav"}}
                <span>Gallery</span>
              </a>
              <a href="/blog/">
                {{> icons/book-open class="icon-nav"}}
                <span>Chronicles</span>
              </a>
              <a href="/about/">
                {{> icons/user class="icon-nav"}}
                <span>Wanderer</span>
              </a>
              <a href="/events/">
                {{> icons/calendar class="icon-nav"}}
                <span>Quests</span>
              </a>
              <a href="/contact/">
                {{> icons/mail class="icon-nav"}}
                <span>Contact</span>
              </a>
              <button class="lang-toggle" type="button" aria-label="Toggle language">
                {{> icons/globe class="icon-nav"}}
                <span>EN</span>
              </button>
            </div>
          </details>
        </nav>
      </header>

      <main class="container page-main">
        {{{ content }}}
      </main>

      <footer class="site-footer">
        <div class="container site-footer-inner">
          <p class="footer-brand">
            {{> icons/feather class="icon-footer"}}
            <span>© 2026 Caelum Nightwhisper. All rights reserved.</span>
          </p>
          <div class="social-row">
            <span>Follow the journey:</span>
            <a href="https://instagram.com/caelumnightwhisper" target="_blank" rel="noopener noreferrer">
              {{> icons/instagram class="icon-footer"}}
              <span>Instagram</span>
            </a>
            <a href="https://twitter.com/caelumnightwhisper" target="_blank" rel="noopener noreferrer">
              {{> icons/twitter class="icon-footer"}}
              <span>Twitter</span>
            </a>
            <a href="https://facebook.com/caelumnightwhisper" target="_blank" rel="noopener noreferrer">
              {{> icons/facebook class="icon-footer"}}
              <span>Facebook</span>
            </a>
            <a href="https://artstation.com/caelumnightwhisper" target="_blank" rel="noopener noreferrer">
              {{> icons/feather class="icon-footer"}}
              <span>ArtStation</span>
            </a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
